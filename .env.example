# Environment variables for Premium Landing Page Starter Kit
# Copy this file to .env.local for local-only values.
# Never commit .env.local or real secrets.

# AI Generation Layer
ANTHROPIC_API_KEY=sk-ant-... # Dein Anthropic API Key

# AI Provider Selection
# Options: "anthropic" (default, requires ANTHROPIC_API_KEY + credits)
#          "mock"      (local development, no API call, no credits needed)
# Never set AI_PROVIDER=mock in production.
AI_PROVIDER=

# Public canonical site URL used for future metadata, previews, or integrations.
# NEXT_PUBLIC_SITE_URL=https://yourdomain.com
